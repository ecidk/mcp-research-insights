  "version": "1.0.0",
  "description": "Research & Insights MCP server for SoundScribe - 18 tools for bulk analysis, validation, and Signal export",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-research-insights": "dist/index.js"
  },
  "author": "ECI Software Solutions",
  "license": "MIT",
  "private": false,
  "repository": {
